# ===========================================
# Monad Testnet Configuration (Primary)
# ===========================================
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_API_KEY=placeholder

# Private Key (DO NOT COMMIT)
PRIVATE_KEY=your_private_key_here

# Pinata IPFS
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt
NEXT_PUBLIC_PINATA_GATEWAY=your_gateway_url

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Contract Addresses (Monad Testnet - after deployment)
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=10143

# Token Addresses (Monad Testnet)
# ⚠️ ETH/USD, USDT/USD, USDC/USD는 Monad Testnet에서 지원 중단됨
# SOL/USD Price Feed만 사용 가능합니다 (src/config/monad.ts 참조)
MONAD_SOL_ADDRESS=0x5387C85A4965769f6B0Df430638a1388493486F1

# Forking (for testing)
FORKING=false

# ===========================================
# Sepolia Testnet (CCIP Cross-Chain)
# ===========================================
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://sepolia.gateway.tenderly.co
SEPOLIA_RPC_URL=https://sepolia.gateway.tenderly.co
NEXT_PUBLIC_SEPOLIA_CHAIN_ID=11155111

# ===========================================
# CCIP Configuration
# ===========================================
# Sepolia CCIP
SEPOLIA_CCIP_ROUTER=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
SEPOLIA_CHAIN_SELECTOR=16015286601757825753
NEXT_PUBLIC_SEPOLIA_LINK_TOKEN=0x779877A7B0D9E8603169DdbD7836e478b4624789

# Monad CCIP (배포 후 업데이트)
NEXT_PUBLIC_MONAD_CCIP_ROUTER=
NEXT_PUBLIC_MONAD_CHAIN_SELECTOR=2183018362218727504

# ===========================================
# NFT Contracts (배포 후 업데이트)
# ===========================================
# Sepolia에서 검증할 NFT 컬렉션
NEXT_PUBLIC_SEPOLIA_NFT_CONTRACT=0x583aeA758A94d74bA997326634B23a2Ea6f4e005

# CCIP 컨트랙트 주소 (배포 후 설정)
NEXT_PUBLIC_SEPOLIA_VERIFIER_ADDRESS=
NEXT_PUBLIC_MONAD_CCIP_RECEIVER_ADDRESS=
