# Monad 네트워크 설정
MONAD_RPC_URL=https://rpc.monad.xyz
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# 배포자 프라이빗 키 (실제 사용 시 보안 주의)
PRIVATE_KEY=your_private_key_here

# VRF 설정 (Chainlink)
VRF_COORDINATOR=0x0000000000000000000000000000000000000000
VRF_SUBSCRIPTION_ID=0
VRF_GAS_LANE=0x474e34a077df58807dbe9c96d3c009b23b3c6d0cce433e59bbf5b34f823bc56c
VRF_CALLBACK_GAS_LIMIT=500000

# 백엔드 설정
PORT=3001
NODE_ENV=development

# 데이터베이스 설정 (MongoDB)
MONGODB_URI=mongodb://localhost:27017/txrpg

# JWT 시크릿
JWT_SECRET=your_jwt_secret_here

# API 키 (선택사항)
ETHERSCAN_API_KEY=your_etherscan_api_key_here 