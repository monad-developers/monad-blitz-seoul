{
  "name": "minecraft-pfp",
  "version": "1.0.0",
  "description": "Minecraft-style PFP NFT with deterministic traits and wealth-based special items",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "compile": "hardhat compile",
    "test:contracts": "hardhat test",
    "deploy:monad": "hardhat run scripts/deploy.ts --network monadTestnet",
    "verify:monad": "hardhat verify --network monadTestnet",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "verify:sepolia": "hardhat verify --network sepolia",
    "migrate:ccip-message-ids": "tsx scripts/migrate-ccip-message-ids.ts",
    "add:ccip-record": "tsx scripts/add-ccip-record-from-tx.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@chainlink/contracts-ccip": "^1.6.3",
    "@napi-rs/canvas": "^0.1.82",
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@react-three/drei": "^9.96.0",
    "@react-three/fiber": "^8.15.0",
    "@supabase/supabase-js": "^2.81.1",
    "@tanstack/react-query": "^5.22.0",
    "clsx": "^2.1.1",
    "ethers": "^6.11.0",
    "gifenc": "^1.0.3",
    "next": "^14.2.0",
    "pinata-web3": "^0.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "skinview3d": "^3.4.1",
    "tailwind-merge": "^3.4.0",
    "three": "^0.160.0",
    "viem": "^2.7.0",
    "wagmi": "^2.5.0"
  },
  "devDependencies": {
    "@chainlink/contracts": "^1.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^5.2.3",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.160.0",
    "autoprefixer": "^10.4.0",
    "chai": "^4.3.0",
    "dotenv": "^16.4.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.0",
    "node-loader": "^2.1.0",
    "postcss": "^8.4.0",
    "solidity-coverage": "^0.8.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@10.12.4"
}
